---
import { experience } from "../data/portfolio.js";
---

<section class="section" id="experience">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Experience</span>
      <h2 class="section-title">Where I've made an <span class="gradient-text">impact</span>.</h2>
      <p class="section-subtitle">
        Building and scaling payment, refund, and reconciliation systems across high-volume fintech platforms.
      </p>
    </div>

    <div class="timeline">
      {experience.map((job) => (
        <article class="tl-item reveal">
          <div class="tl-marker">
            <span class={`tl-dot ${job.current ? "active" : ""}`}></span>
          </div>

          <div class="tl-card card">
            <div class="tl-head">
              <div>
                <h3 class="tl-role">{job.role}</h3>
                <p class="tl-company">
                  <span class="tl-company-name">{job.company}</span>
                  <span class="tl-loc">· {job.location}</span>
                </p>
              </div>
              <span class={`tl-period ${job.current ? "now" : ""}`}>{job.period}</span>
            </div>

            <ul class="tl-points">
              {job.points.map((pt) => <li>{pt}</li>)}
            </ul>

            <div class="tl-tags">
              {job.tags.map((t) => <span class="chip">{t}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline {
    position: relative;
    margin-left: 8px;
  }
  .timeline::before {
    content: "";
    position: absolute;
    left: 6px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: linear-gradient(to bottom, var(--accent), var(--accent-2), transparent);
    opacity: 0.4;
  }

  .tl-item {
    position: relative;
    padding-left: 40px;
    padding-bottom: 28px;
  }
  .tl-item:last-child {
    padding-bottom: 0;
  }
  .tl-marker {
    position: absolute;
    left: 0;
    top: 26px;
  }
  .tl-dot {
    display: block;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--border-strong);
    margin-left: -1px;
  }
  .tl-dot.active {
    background: var(--gradient);
    border-color: transparent;
    box-shadow: 0 0 0 4px rgba(109, 139, 255, 0.18), var(--glow);
  }

  .tl-card {
    padding: 24px 26px;
  }
  .tl-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 16px;
  }
  .tl-role {
    font-size: 1.18rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .tl-company {
    font-size: 0.92rem;
    color: var(--text-muted);
    margin-top: 3px;
  }
  .tl-company-name {
    color: var(--accent);
    font-weight: 600;
  }
  .tl-loc {
    color: var(--text-dim);
  }
  .tl-period {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-dim);
    padding: 5px 12px;
    border: 1px solid var(--border);
    border-radius: 999px;
    white-space: nowrap;
  }
  .tl-period.now {
    color: var(--accent-3);
    border-color: rgba(54, 214, 195, 0.3);
    background: rgba(54, 214, 195, 0.06);
  }

  .tl-points {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 11px;
    margin-bottom: 18px;
  }
  .tl-points li {
    position: relative;
    padding-left: 22px;
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .tl-points li::before {
    content: "";
    position: absolute;
    left: 2px;
    top: 0.62em;
    width: 6px;
    height: 6px;
    border-radius: 2px;
    background: var(--accent);
    transform: rotate(45deg);
  }

  .tl-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  @media (max-width: 560px) {
    .tl-head {
      flex-direction: column;
      gap: 8px;
    }
    .tl-card {
      padding: 20px;
    }
  }
</style>
