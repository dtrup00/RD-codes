---
import { contact, profile } from "../data/portfolio.js";
---

<section class="section contact-section" id="contact">
  <div class="container">
    <div class="contact-card reveal">
      <span class="eyebrow" style="justify-content:center;">Get in touch</span>
      <h2 class="contact-title">
        Let's build something <span class="gradient-text">great</span> together.
      </h2>
      <p class="contact-sub">
        I'm always open to discussing backend engineering roles, system design challenges, or interesting projects. Drop me a line — I'll get back to you.
      </p>

      <div class="contact-actions">
        <a href={`mailto:${contact.email}`} class="btn btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
          {contact.email}
        </a>
      </div>

      <div class="contact-links">
        <a href={contact.github} target="_blank" rel="noopener" class="contact-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.37.5 0 5.78 0 12.29c0 5.2 3.44 9.61 8.21 11.16.6.11.82-.25.82-.56 0-.28-.01-1.02-.02-2-3.34.71-4.04-1.58-4.04-1.58-.55-1.37-1.34-1.74-1.34-1.74-1.09-.73.08-.72.08-.72 1.2.08 1.84 1.21 1.84 1.21 1.07 1.79 2.81 1.27 3.5.97.11-.76.42-1.27.76-1.56-2.67-.3-5.47-1.31-5.47-5.84 0-1.29.47-2.34 1.24-3.17-.12-.3-.54-1.52.12-3.17 0 0 1.01-.32 3.3 1.21a11.6 11.6 0 0 1 6 0c2.29-1.53 3.3-1.21 3.3-1.21.66 1.65.24 2.87.12 3.17.77.83 1.23 1.88 1.23 3.17 0 4.54-2.81 5.53-5.49 5.83.43.36.81 1.08.81 2.18 0 1.57-.01 2.84-.01 3.23 0 .31.21.68.83.56A12.04 12.04 0 0 0 24 12.29C24 5.78 18.63.5 12 .5Z"/></svg>
          GitHub
        </a>
        <a href={contact.linkedin} target="_blank" rel="noopener" class="contact-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.13 2.07 2.07 0 0 1 0 4.13ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z"/></svg>
          LinkedIn
        </a>
        <a href={`tel:${contact.phone}`} class="contact-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
          {contact.phone}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding-bottom: 40px;
  }
  .contact-card {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
    padding: 56px 40px;
    border-radius: 24px;
    background:
      radial-gradient(60rem 30rem at 50% -40%, rgba(109, 139, 255, 0.18), transparent 70%),
      var(--bg-card);
    border: 1px solid var(--border-strong);
    position: relative;
    overflow: hidden;
  }
  .contact-card::before {
    content: "";
    position: absolute;
    inset: 0;
    padding: 1px;
    border-radius: 24px;
    background: var(--gradient);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0.25;
    pointer-events: none;
  }
  .contact-title {
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 6px 0 16px;
  }
  .contact-sub {
    color: var(--text-muted);
    max-width: 520px;
    margin: 0 auto 32px;
    font-size: 1.02rem;
  }
  .contact-actions {
    margin-bottom: 28px;
  }
  .contact-actions .btn {
    font-size: 0.96rem;
  }
  .contact-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }
  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 10px 18px;
    border-radius: 999px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.88rem;
    transition: transform 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .contact-link:hover {
    transform: translateY(-2px);
    color: var(--text);
    border-color: var(--accent);
  }

  @media (max-width: 560px) {
    .contact-card {
      padding: 40px 22px;
    }
    .contact-actions .btn {
      font-size: 0.82rem;
      word-break: break-all;
    }
  }
</style>
